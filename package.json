{
  "name": "looma",
  "productName": "Looma",
  "private": true,
  "version": "0.1.0",
  "build": {
    "appId": "com.looma.app",
    "productName": "Looma",
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "packageManager": "pnpm@10.32.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run clean && pnpm run copy-config && vite",
    "build": "pnpm run clean && tsc && vite build && electron-builder",
    "rebuild": "electron-rebuild",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rimraf dist-electron",
    "copy-config": "cpx \"electron/config/**/*\" dist-electron/config",
    "memory:smoke": "pnpm run clean && vite build --mode development && rm -rf .local && mkdir -p .local && LOOMA_DB_PATH=\"$PWD/.local/memory-smoke.db\" electron ./dist-electron/memorySmoke.js",
    "models:smoke": "pnpm run clean && vite build --mode development && rm -rf .local && mkdir -p .local && LOOMA_DB_PATH=\"$PWD/.local/models-smoke.db\" electron ./dist-electron/modelSmoke.js",
    "strategy:smoke": "pnpm run clean && vite build --mode development && rm -rf .local && mkdir -p .local && LOOMA_DB_PATH=\"$PWD/.local/strategy-smoke.db\" electron ./dist-electron/strategySwitchSmoke.js",
    "memory-cloud:smoke": "pnpm run clean && vite build --mode development && rm -rf .local && mkdir -p .local && LOOMA_DB_PATH=\"$PWD/.local/memory-cloud-smoke.db\" electron ./dist-electron/strategyMemoryCloudSmoke.js",
    "strategy-memory:smoke": "pnpm run clean && vite build --mode development && rm -rf .local && mkdir -p .local && LOOMA_DB_PATH=\"$PWD/.local/strategy-memory-smoke.db\" electron ./dist-electron/strategyMemorySmoke.js",
    "attachments:matrix": "npx esbuild scripts/attachment_policy_matrix.ts --bundle --platform=node --format=esm --outfile=/tmp/attachment-policy-matrix.mjs && node /tmp/attachment-policy-matrix.mjs",
    "attachments:compat-report": "mkdir -p .local && npx esbuild scripts/provider_attachment_compatibility_report.ts --bundle --platform=node --format=esm --outfile=.local/provider-attachment-compat-report.mjs && node .local/provider-attachment-compat-report.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@lobehub/icons": "^5.0.1",
    "@mozilla/readability": "^0.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.11",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corner-smoothing": "^0.1.5",
    "dotenv": "^17.3.1",
    "esbuild": "^0.21.5",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.541.0",
    "next-themes": "^0.4.6",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.11",
    "use-sync-external-store": "^1.5.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "cpx": "^1.5.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "rimraf": "^6.1.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-static-copy": "^3.1.1"
  },
  "main": "dist-electron/main.js"
}
