{
  "name": "afferlab",
  "productName": "AfferLab",
  "description": "Strategy-driven AI workspace",
  "author": "AfferLab",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "build": {
    "appId": "com.afferlab.app",
    "productName": "AfferLab",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/.pnpm/better-sqlite3@*/node_modules/better-sqlite3/build/**/*"
    ],
    "npmRebuild": true,

    "directories": {
      "buildResources": "build",
      "output": "release/${version}"
    },

    "files": [
      "dist",
      "dist-electron",
      "node_modules/.pnpm/better-sqlite3@*/node_modules/better-sqlite3/build/**/*",
      "node_modules/.pnpm/bindings@*/node_modules/bindings/**/*",
      "node_modules/.pnpm/file-uri-to-path@*/node_modules/file-uri-to-path/**/*"
    ],

    "mac": {
      "icon": "build/icon.icns",
      "target": ["dmg"],
      "artifactName": "${productName}-Mac-${version}-Installer.${ext}",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },

    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
    },

    "linux": {
      "icon": "build/icon.png",
      "artifactName": "${productName}-Linux-${version}.${ext}"
    },
    "dmg": {
      "title": "AfferLab Installer",
      "background": "assets/dmg-background.png",
      "iconSize": 120,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },

    "publish": [
      {
        "provider": "github",
        "owner": "afferlab",
        "repo": "afferlab"
      }
    ],
    "extraResources": [
      {
        "from": "electron/config",
        "to": "config"
      }
    ]
  },
  "packageManager": "pnpm@10.32.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run clean && pnpm run copy-config && vite",
    "build": "pnpm run clean && tsc && vite build && electron-builder",
    "rebuild": "electron-rebuild",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rimraf dist-electron",
    "copy-config": "cpx \"electron/config/**/*\" dist-electron/config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@lobehub/icons": "^5.0.1",
    "@mozilla/readability": "^0.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.11",
    "better-sqlite3": "^12.2.0",
    "bindings": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corner-smoothing": "^0.1.5",
    "dotenv": "^17.3.1",
    "esbuild": "^0.21.5",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.541.0",
    "next-themes": "^0.4.6",
    "pdf-parse": "^1.1.1",
    "prebuild-install": "^7.1.3",
    "electron-updater": "^6.6.2",
    "file-uri-to-path": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.11",
    "use-sync-external-store": "^1.5.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "cpx": "^1.5.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "rimraf": "^6.1.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-static-copy": "^3.1.1"
  },
  "main": "dist-electron/main.js"
}
